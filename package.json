{
  "name": "ledger",
  "version": "1.1.1",
  "main": "dist/main.js",
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "start": "npm run build && ELECTRON_RUN_AS_NODE= electron . --no-sandbox",
    "dev": "npm run build && ELECTRON_RUN_AS_NODE= electron . --no-sandbox",
    "dist": "NODE_ENV=production npm run build && electron-builder",
    "dist:win": "NODE_ENV=production npm run build && electron-builder --win",
    "dist:linux": "NODE_ENV=production npm run build && electron-builder --linux",
    "dist:mac": "NODE_ENV=production npm run build && electron-builder --mac"
  },
  "keywords": [],
  "author": {
    "name": "Ledger",
    "email": "support@ledger.app"
  },
  "homepage": "https://github.com/ledger/ledger-accounting",
  "license": "ISC",
  "description": "Double-entry accounting desktop application",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "css-loader": "^7.1.4",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.6.6",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "build": {
    "appId": "com.ledger.accounting",
    "productName": "Ledger",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron-bootstrap.js",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.finance",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Office",
      "icon": "build/icons"
    }
  }
}
